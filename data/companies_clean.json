  "dimensions": [
    {
      "id": "privacy",
      "name": "Privacy & Data Protection",
      "description": "How does the company handle user data? Are there transparency requirements, opt-out options, and clear data minimization practices?",
      "weight": 1.0
    },
    {
      "id": "transparency",
      "name": "Transparency & Disclosure",
      "description": "How openly does the company communicate about their AI systems, limitations, and practices?",
      "weight": 1.0
    },
    {
      "id": "liability",
      "name": "Liability & Safety",
      "description": "How does the company handle responsibility for AI harms and implement safety measures?",
      "weight": 1.0
    },
    {
      "id": "user_rights",
      "name": "User Rights & Control",
      "description": "What data rights do users have? Can they delete data, export it, and control how it's used?",
      "weight": 1.0
    },
    {
      "id": "government",
      "name": "Government Transparency & Accountability",
      "description": "How transparent is the company about government data requests and contracts?",
      "weight": 1.0
    },
    {
      "id": "ethics",
      "name": "Values & Ethical Commitment",
      "description": "Does the company demonstrate commitment to ethical AI through research, practices, and long-term accountability?",
      "weight": 1.0
    }
